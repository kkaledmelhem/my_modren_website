# Spring Boot Portfolio — Environment Variables
# Copy this to .env for local development

# AI Chat (Groq - free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL
# Option A - Railway (auto-injected)
PGHOST=localhost
PGPORT=5432
PGDATABASE=portfolio
PGUSER=postgres
PGPASSWORD=your_password

# Option B - Neon (single URL, set DATABASE_URL)
# DATABASE_URL=jdbc:postgresql://ep-xxx.neon.tech/neondb?sslmode=require

# Redis
# Railway: redis://default:password@host:port
# Upstash: rediss://default:password@host:6380
REDIS_URL=redis://localhost:6379

# Optional
LIQUIBASE_ENABLED=true
